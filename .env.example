# Get these from expo.dev project:
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_DEMO_MODE=false
# Disable phone auth (falls back to reCAPTCHA without APNs Auth Key registered
# in Firebase Console — brittle). Default false; set true if APNs not ready.
EXPO_PUBLIC_DISABLE_PHONE_AUTH=false

# Sentry DSN for crash + performance telemetry. Leave empty to disable.
EXPO_PUBLIC_SENTRY_DSN=

# TestFlight public invite URL (swap landing CTA from waitlist form to TF).
# Used by landing-pg at build time via NEXT_PUBLIC_TESTFLIGHT_URL.
NEXT_PUBLIC_TESTFLIGHT_URL=
