rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // users/{uid}
    // -------------------------------------------------------------------------
    // Any signed-in user can read any user doc (public profiles, partner
    // lookup, referral flows all need cross-user reads).
    //
    // Full write access is owner-only. Cross-user reputation updates are
    // handled exclusively by Cloud Functions (awardReferral) using the
    // admin SDK, which bypasses these rules entirely.
    match /users/{uid} {
      allow read: if request.auth != null;

      // Owner: full write access (profile setup, profile updates) EXCEPT
      // tamper-resistant fields written only by Cloud Functions:
      //   - legal acceptance (acceptLegalTerms CF)
      //   - KYC / Stripe account fields (createConnectAccount + linkBankAccount CFs)
      //   - forgiveness + promo flags (handleSessionForfeit, maybeAwardFinalsPromo)
      allow write: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny([
                'legalAcceptanceVersion', 'legalAcceptedAt',
                'stripeAccountId', 'stripeAccountStatus', 'stripeKycProvidedAt',
                'legalFirstName', 'legalLastName',
                'linkedBank', 'plaidAccessToken', 'plaidItemId', 'plaidAccountId',
                'firstSurrenderForgiven', 'firstSurrenderForgivenAt',
                'finalsPromoAwarded', 'finalsPromoAwardedAt'
              ]);

      // Initial profile creation (no existing doc — resource is null)
      allow create: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.keys().hasAny([
             'legalAcceptanceVersion', 'legalAcceptedAt',
             'stripeAccountId', 'stripeAccountStatus', 'stripeKycProvidedAt',
             'legalFirstName', 'legalLastName',
             'linkedBank', 'plaidAccessToken', 'plaidItemId', 'plaidAccountId',
             'firstSurrenderForgiven', 'firstSurrenderForgivenAt',
             'finalsPromoAwarded', 'finalsPromoAwardedAt'
           ]);
    }

    // -------------------------------------------------------------------------
    // wallets/{uid}
    // -------------------------------------------------------------------------
    // Owner-read-only. Client writes are restricted to initial creation with a
    // zero balance (saveUserProfile initializes the wallet once on first signup).
    // All balance mutations happen server-side via Cloud Functions, which use
    // the admin SDK and bypass these rules entirely.
    match /wallets/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Allow initial wallet creation only — balance must start at zero.
      // Enforce numeric types to prevent string "0" bypassing downstream checks.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.balance is number
        && request.resource.data.balance == 0
        && request.resource.data.pendingBalance is number
        && request.resource.data.pendingBalance == 0;

      // No client-side updates or deletes — handled exclusively by Cloud Functions.
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // userFollows/{uid}
    // -------------------------------------------------------------------------
    // Any signed-in user can read follows docs (social graph is public).
    //
    // follow/unfollow operations are handled by Cloud Functions (followUser,
    // unfollowUser) using the admin SDK, which bypasses these rules.
    // Owner can still write their own doc for backwards compatibility.
    match /userFollows/{uid} {
      allow read: if request.auth != null;

      // All follow/unfollow writes handled by Cloud Functions (admin SDK).
      // Previously allowed owner writes for backwards compatibility — removed
      // because it let users forge follower arrays directly.
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // sessions/{sessionId}
    // -------------------------------------------------------------------------
    // Session documents track solo focus sessions. Written client-side by
    // sessionStore (writeSession, updateSession) and server-side by Cloud
    // Functions (handleSessionComplete, handleSessionForfeit — admin SDK).
    //
    // Owner can read and create sessions. Updates are restricted to status
    // transitions only (complete/surrender). Cloud Functions bypass these
    // rules via admin SDK for authoritative balance mutations.
    match /sessions/{sessionId} {
      // Owner can read their own sessions
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Owner can create sessions (userId must match auth, status must be active).
      // Enforce types on financial fields to prevent type-confusion attacks.
      allow create: if request.auth != null
        && request.resource.data.userId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status is string
        && request.resource.data.status == 'active'
        && request.resource.data.stakeAmount is number
        && request.resource.data.stakeAmount > 0;

      // Owner can update their own sessions — restricted to status transition
      // fields only. Financial fields (stakeAmount, potentialPayout, endsAt)
      // are immutable after creation. Cloud Functions use admin SDK for
      // authoritative balance mutations and can write any field.
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'completedAt', 'updatedAt']);

      // No client-side deletes
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // rateLimits/{docId}
    // -------------------------------------------------------------------------
    // Written exclusively by Cloud Functions (admin SDK) for server-side
    // rate limiting. No client access — explicit deny for defense-in-depth.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // revenue/{docId}
    // -------------------------------------------------------------------------
    // Written by Cloud Functions when sessions are forfeited. No client access.
    match /revenue/{docId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // transactions/{docId}
    // -------------------------------------------------------------------------
    // Written by Cloud Functions for deposit/withdrawal/payout records.
    // Owner can read their own transactions.
    match /transactions/{docId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // groupSessions/{sessionId}
    // -------------------------------------------------------------------------
    // Participants can read their own group sessions. All writes happen
    // exclusively via Cloud Functions (admin SDK) to enforce server-authoritative
    // session lifecycle, payout calculations, and stake management.
    match /groupSessions/{sessionId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantIds;

      // No client-side writes — all managed by Cloud Functions
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // groupInvites/{inviteId}
    // -------------------------------------------------------------------------
    // Recipients can read invites sent to them. Proposers can read invites
    // they sent. All writes (create, accept, decline, expire) happen via
    // Cloud Functions to enforce stake deduction and session state transitions.
    match /groupInvites/{inviteId} {
      allow read: if request.auth != null
        && (resource.data.toUserId == request.auth.uid
            || resource.data.fromUserId == request.auth.uid);

      // No client-side writes — all managed by Cloud Functions
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // analytics_events/{eventId}
    // -------------------------------------------------------------------------
    // Authenticated users append their own milestone events. No reads — the
    // aggregateDailyMetrics Cloud Function reads server-side. userId may be
    // null for pre-auth events (e.g. install/app_open before sign-in).
    match /analytics_events/{eventId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.resource.data.name is string
        && (request.resource.data.userId == null
            || request.resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // metrics/{YYYY-MM-DD}
    // -------------------------------------------------------------------------
    // Daily rollup written by aggregateDailyMetrics. Readable by any signed-in
    // user (for an in-app dashboard later). No client writes.
    match /metrics/{dateId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // config/featureFlags
    // -------------------------------------------------------------------------
    // Public read-only server-controlled kill switches. Fields:
    //   acceptingDeposits, acceptingWithdrawals, groupSessionsEnabled,
    //   soloSessionsEnabled
    // Any authenticated user can read so the client can honor a toggle live.
    // Writes are console-only (admin console, or gcloud) — never client.
    match /config/featureFlags {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // Default deny
    // -------------------------------------------------------------------------
    // Any collection not explicitly matched above is denied by default.
    // This covers future collections (groupSessions, groupInvites, etc.)
    // until explicit rules are added for them.
  }
}
