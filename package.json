{
  "name": "niyah",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "start": "node scripts/print-dev-url.js & expo start --dev-client",
    "start:device": "SKIP_BUILD=true bash scripts/dev-device.sh",
    "start:go": "expo start --go",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "build:local": "npx expo run:ios --device",
    "build:local:sim": "npx expo run:ios",
    "build:dev": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:device": "eas build --profile development-device --platform ios",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "test": "cross-env EXPO_PUBLIC_DEMO_MODE=true jest",
    "test:watch": "jest --watch",
    "test:coverage": "cross-env EXPO_PUBLIC_DEMO_MODE=true jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:stores": "jest --testPathPattern=store",
    "test:components": "jest --testPathPattern=components",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "dependencies": {
    "@bottom-tabs/react-navigation": "^1.1.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/firestore": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-native-google-signin/google-signin": "^14.0.2",
    "@react-navigation/native": "^7.2.0",
    "@stripe/stripe-react-native": "^0.59.2",
    "expo": "~54.0.33",
    "expo-apple-authentication": "^8.0.8",
    "expo-auth-session": "^7.0.10",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "^6.0.20",
    "expo-haptics": "^15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-screen-capture": "^8.0.9",
    "expo-secure-store": "^55.0.9",
    "expo-sms": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "^1.0.8",
    "expo-web-browser": "^15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-bottom-tabs": "^1.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-plaid-link-sdk": "^12.8.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-ssl-public-key-pinning": "^1.2.6",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "^0.7.4",
    "sf-symbols-typescript": "^2.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.17",
    "babel-preset-expo": "^54.0.10",
    "cross-env": "^10.1.0",
    "eas": "^0.1.0",
    "eas-cli": "^18.4.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest-expo": "^54.0.17",
    "prettier": "^3.8.1",
    "react-native-web": "~0.20.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "tar": "7.5.10",
      "minimatch@5": "5.1.8",
      "ajv@8": "8.18.0",
      "node-forge": ">=1.3.2"
    }
  }
}
