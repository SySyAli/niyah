# ─── Google OAuth ────────────────────────────────────────────────────────────
# From Google Cloud Console: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
# From Stripe Dashboard: https://dashboard.stripe.com/apikeys
# Use pk_test_... for development, pk_live_... for production
# NEVER commit secret keys (sk_...) — those go in Firebase Secret Manager only
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ─── Firebase Cloud Functions ────────────────────────────────────────────────
# Secret key set via: firebase functions:secrets:set STRIPE_SECRET_KEY
# Webhook secret set via: firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
# (These are never stored in .env — managed by Firebase Secret Manager)
